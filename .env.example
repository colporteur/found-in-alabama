# Copy to .env.local for local dev (or run `vercel env pull .env.local` after
# setting these in the Vercel dashboard).
# DO NOT COMMIT real values — .env.local is gitignored.

# ─── NextAuth (auto-generated by Vercel + filled in manually) ────────────────
AUTH_SECRET=
AUTH_URL=https://www.foundinalabama.com
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="Found in Alabama <hello@foundinalabama.com>"
ADMIN_EMAIL=colporteurbooks@gmail.com

# ─── Vercel Postgres (auto-injected by Vercel when DB is provisioned) ────────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Anthropic (Phase 2B onward) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── eBay Trading API (Phase eBay-1 — re-categorization tool) ────────────────
# All four are from https://developer.ebay.com → My Account → Application
# Keysets. EBAY_AUTH_TOKEN is generated separately at "User Tokens" — see
# PHASE-EBAY-1-SETUP.md for the step-by-step.
EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=
EBAY_AUTH_TOKEN=
# 'production' or 'sandbox'. Always 'production' once you're done testing.
EBAY_ENV=production
# 0 = US, 3 = UK, 77 = Germany, etc. Leave at 0 unless you sell on a non-US site.
EBAY_SITE_ID=0
# Optional: set to 1 to log Trading API request/response XML to server logs.
# EBAY_DEBUG=1

# ─── eBay OAuth (Phase eBay-2 — sales + Sell APIs) ───────────────────────────
# Generate a RuName at developer.ebay.com → User Tokens → "Add eBay Redirect URL".
# It looks like "TKnH-Inventor-1234-abcdef" (NOT a regular URL — eBay's identifier
# for the redirect URL you registered there).
EBAY_RU_NAME=
# The actual https URL eBay should redirect back to after consent. Must EXACTLY
# match what you typed into the dev portal. In production:
#   https://www.foundinalabama.com/api/admin/ebay/oauth/callback
EBAY_OAUTH_REDIRECT_URI=
# Random string used to sign OAuth state tokens. Generate with:
#   openssl rand -base64 32
EBAY_OAUTH_STATE_SECRET=
